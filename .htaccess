# flore.nz — Redirect-Regeln (Apache / LiteSpeed)
#
# Root (/) zeigt die Profilseite. Alles andere wird dauerhaft (301) und
# path-erhaltend auf blog.flore.nz weitergeleitet. Query-String bleibt erhalten.
#
# Liegt im Web-Root direkt neben index.html.

RewriteEngine On

# 0. Canonical Host: www auf non-www umleiten.
RewriteCond %{HTTP_HOST} ^www\.flore\.nz$ [NC]
RewriteRule ^ https://flore.nz%{REQUEST_URI} [R=301,L,NE]

# 1. Bestehende Dateien und Ordner am Root weiter ausliefern
#    (index.html, die Profil-Bilder, usw.) — sonst bräche die Profilseite.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 2. Legacy-/blog-Pfade ohne den Prefix auf den Blog umleiten.
RewriteRule ^blog/?$ https://blog.flore.nz/ [R=301,L,QSA]
RewriteRule ^blog/(.+)$ https://blog.flore.nz/$1 [R=301,L,QSA]

# 3. Alles Übrige: 301 auf blog.flore.nz, gleicher Pfad, Query angehängt.
#    ^(.+)$ greift nur bei nicht-leerem Pfad, der Root (^$) bleibt also außen vor.
RewriteRule ^(.+)$ https://blog.flore.nz/$1 [R=301,L,QSA]
